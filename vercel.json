{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://divg-backend.onrender.com/api/:path*" },
    { "source": "/((?!catalog\\.html|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}