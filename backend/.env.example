# ─── PORT ─────────────────────────────────────────
PORT=4000

# ─── SUI Testnet ──────────────────────────────────
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=0x82a9bfbffccce9057b12f9b1b53bc1f5f25e3ef8f68346899892f8facdd82a33
SUI_REGISTRY_ID=
SUI_ADMIN_CAP=
# Output of: sui keytool export --key-identity <addr>
# Format: suiprivkey1...
SUI_ADMIN_PRIVATE_KEY=

# ─── Hedera Testnet ───────────────────────────────
# Get free testnet account: https://portal.hedera.com
HEDERA_ACCOUNT_ID=
HEDERA_PRIVATE_KEY=
HEDERA_TOPIC_ID=

# ─── API Keys ──────────────────────────────────────────────
SERP_API_KEY=
RESEND_API_KEY=
RESEND_FROM=
SERP_STRICT=
FRED_API_KEY=

# Comma-separated emails that bypass the SerpAPI anti-sybil gate (demo operator).
WHITELISTED_EMAILS=

# Optional: enables the AI Benchmarking Agent + site Assistant (Gemini).
# If unset, both fall back to an offline summary instead of failing.
# Get a free key at https://aistudio.google.com  (do NOT enable Cloud billing
# if you want to stay strictly on the free tier).
GEMINI_API_KEY=

# ─── Walrus (testnet defaults already set in code) ─────────
# Override only if you run your own publisher/aggregator.
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# DIVG AI Benchmarking Agent Key
GEMINI_API_KEY=
